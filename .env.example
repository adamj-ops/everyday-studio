# Copy to .env.local and fill in. .env.local is gitignored.

# Anthropic (Claude two-tier: Sonnet operator + Opus reviewer)
ANTHROPIC_API_KEY=

# Defaults set in lib/claude/client.ts; override here if you want a different model.
CLAUDE_OPERATOR_MODEL=claude-sonnet-4-6
CLAUDE_REVIEWER_MODEL=claude-opus-4-7

# Google Gemini (rendering primary, gemini-3-pro-image-preview)
GEMINI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only needed for `supabase db push` from this machine.
SUPABASE_DB_PASSWORD=
